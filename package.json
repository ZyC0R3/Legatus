{
  "name": "legatus",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Legatus is a TypeScript Discord moderation bot built without a database.",
  "engines": {
    "node": ">=24.7.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "prestart": "npm run build",
    "register:commands": "tsx src/register-commands.ts",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}